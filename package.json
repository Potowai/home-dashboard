{
  "name": "home-dashboard",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "server": "nodemon server.cjs",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "bash -lc \"source /home/user/.nvm/nvm.sh && tsc -b && vite build\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "restart": "sudo -n systemctl restart home-dashboard.service",
    "deploy": "bash ./deploy.sh",
    "watch:deploy": "nodemon --watch src --watch public --watch server.cjs --watch package.json --watch .env --ext js,jsx,ts,tsx,cjs,json,css,html --ignore dist --ignore node_modules --delay 1 --exec \"bash ./deploy.sh\""
  },
  "dependencies": {
    "@mantine/core": "^8.3.18",
    "@mantine/form": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@types/react-grid-layout": "^1.3.6",
    "@types/recharts": "^1.8.29",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^2.2.2",
    "recharts": "^3.8.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "systeminformation": "^5.31.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cssnano": "^7.1.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "postcss-import": "^16.1.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
